<Window x:Class="MhxyAssistant.App.Windows.AiSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Settings" Height="520" Width="660"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="OpenAI-compatible assistant" FontSize="18" FontWeight="SemiBold" />

        <Grid Grid.Row="1" Margin="0,18,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Enabled" VerticalAlignment="Center" Margin="0,0,12,8" />
            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding Enabled}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Provider" VerticalAlignment="Center" Margin="0,0,12,8" />
            <ComboBox Grid.Row="1" Grid.Column="1" Text="{Binding Provider, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Margin="0,0,0,8">
                <ComboBoxItem Content="openai" />
                <ComboBoxItem Content="custom" />
            </ComboBox>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Base URL" VerticalAlignment="Center" Margin="0,0,12,8" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Model" VerticalAlignment="Center" Margin="0,0,12,8" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="API key" VerticalAlignment="Center" Margin="0,0,12,8" />
            <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="ApiKeyBox" PasswordChanged="ApiKeyBox_OnPasswordChanged" Margin="0,0,0,8" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Test message" VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding TestMessage, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <TextBox Grid.Row="2"
                 Text="{Binding ChatResponse, Mode=OneWay}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" TextWrapping="Wrap" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Check" Width="84" Margin="8,0,0,0" Command="{Binding TestCommand}" />
                <Button Content="Chat Test" Width="92" Margin="8,0,0,0" Command="{Binding ChatTestCommand}" />
                <Button Content="Save" Width="84" Margin="8,0,0,0" Command="{Binding SaveCommand}" />
                <Button Content="Close" Width="84" Margin="8,0,0,0" Click="Close_OnClick" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
